# Optional: OpenAI API key if you switch to Whisper API later
# OPENAI_API_KEY=

# Optional: AssemblyAI / Deepgram for diarization (Phase 2)
# ASSEMBLYAI_API_KEY=
# DEEPGRAM_API_KEY=

# Storage path (default: ./storage)
# STORAGE_PATH=./storage

# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# Set to 1 if you get SSL certificate errors (e.g. corporate proxy with self-signed cert).
# Only use in trusted environments; disables HTTPS verification for model downloads.
# DISABLE_SSL_VERIFY=1

# Speaker diarization (pyannote): free, runs locally after first download.
# 1) Create a token at https://huggingface.co/settings/tokens
# 2) Accept the model license: https://huggingface.co/pyannote/speaker-diarization-3.1
# 3) Set HF_TOKEN=your_token_here (optional: set DIARIZATION_ENABLED=0 to disable)
# HF_TOKEN=
# DIARIZATION_ENABLED=1
